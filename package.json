{
  "name": "f76qc2",
  "private": true,
  "version": "2.0.0-beta.2",
  "type": "module",
  "author": "FelisDiligens",
  "license": "MIT",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "preinstall": "npx --yes only-allow pnpm",
    "dev": "tauri dev",
    "build": "tauri build",
    "test": "pnpm run ui:vitest && pnpm run cargo:nextest",
    "test-all": "pnpm run ui:vitest && pnpm run cargo:nextest-all",
    "lint": "pnpm run ui:lint && pnpm run cargo:clippy",
    "lint:fix": "tsc --noEmit && eslint ./src --ext .js,.ts,.jsx,.tsx --fix && pnpm run cargo:clippy -- --fix",
    "format": "prettier \"./src/**/*.{js,ts,jsx,tsx}\" --write && cargo fmt --manifest-path ./src-tauri/Cargo.toml",
    "export-bindings": "cargo run --manifest-path ./src-tauri/Cargo.toml -- --export-bindings",
    "cargo:run": "cargo run --manifest-path ./src-tauri/Cargo.toml",
    "cargo:test": "cargo test --manifest-path ./src-tauri/Cargo.toml -- --nocapture",
    "cargo:nextest": "cargo llvm-cov nextest --html --manifest-path ./src-tauri/Cargo.toml && rm -rf ./coverage/llvm-cov/ && mv -v ./src-tauri/target/llvm-cov/html/ ./coverage/llvm-cov/",
    "cargo:nextest-all": "cargo llvm-cov nextest --run-ignored=all --html --manifest-path ./src-tauri/Cargo.toml && rm -rf ./coverage/llvm-cov/ && mv -v ./src-tauri/target/llvm-cov/html/ ./coverage/llvm-cov/",
    "cargo:check": "cargo check --manifest-path ./src-tauri/Cargo.toml",
    "cargo:clippy": "cargo clippy --manifest-path ./src-tauri/Cargo.toml",
    "cargo:fmt": "cargo fmt --manifest-path ./src-tauri/Cargo.toml",
    "ui:vitest": "vitest run --coverage --coverage.reportsDirectory=./coverage/vitest",
    "ui:lint": "tsc --noEmit && eslint ./src --ext .js,.ts,.jsx,.tsx",
    "ui:tsc": "tsc --noEmit",
    "ui:eslint": "eslint ./src --ext .js,.ts,.jsx,.tsx",
    "ui:format": "prettier \"./src/**/*.{js,ts,jsx,tsx}\" --write",
    "tauri": "tauri",
    "vite:dev": "vite serve",
    "vite:build": "tsc && vite build",
    "vite:preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/noto-mono": "^5.2.5",
    "@fontsource/roboto": "^5.2.9",
    "@fontsource/roboto-condensed": "^5.2.8",
    "@formkit/drag-and-drop": "^0.5.3",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-http": "~2.5.7",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@uiw/react-codemirror": "^4.25.4",
    "bootstrap": "^5.3.8",
    "classnames": "^2.5.1",
    "deepmerge": "^4.3.1",
    "fast-copy": "^4.0.3",
    "fast-deep-equal": "^3.1.3",
    "i18next": "^25.8.11",
    "i18next-browser-languagedetector": "^8.2.1",
    "immer": "^11.1.4",
    "jotai": "^2.18.0",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.1",
    "mitt": "^3.0.1",
    "moment": "^2.30.1",
    "object-inspect": "^1.13.4",
    "object-path": "^0.11.8",
    "react": "^19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^16.5.4",
    "react-photo-view": "^1.2.7",
    "react-range": "^1.10.0",
    "react-router-dom": "^7.13.0",
    "use-debounce": "^10.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.3.0",
    "@types/object-inspect": "^1.13.0",
    "@types/object-path": "^0.11.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.27.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "sass": "^1.78.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-fetch-mock": "^0.4.5"
  }
}
